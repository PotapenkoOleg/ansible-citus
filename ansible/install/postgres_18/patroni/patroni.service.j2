[Unit]
Description=Patroni service
Documentation=https://github.com/patroni/patroni
After=syslog.target network.target

[Service]
Type=simple
User=postgres
Group=postgres
ExecStart=/usr/local/bin/patroni /etc/patroni/{{ PATRONI_CLUSTER_NAME }}.yml
KillMode=process
TimeoutSec=30
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
